# Databricks Configuration
# Copy this file to .env and fill in your actual values

# Workspace hostname, e.g. dbc-xxxx.cloud.databricks.com (no https://)
TAP_DATABRICKS_SERVER_HOSTNAME=your_workspace_hostname

# SQL Warehouse / cluster HTTP path, e.g. /sql/1.0/warehouses/abc123
TAP_DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/your_http_path

# Unity Catalog catalog to extract from
TAP_DATABRICKS_CATALOG=your_catalog

# Optional: Optional schema to scope extraction; if omitted, all schemas in the catalog are discovered
TAP_DATABRICKS_SCHEMA=your_schema

# --- Authentication (Choose one) ---

# Choice 1: Databricks personal access token (PAT)
TAP_DATABRICKS_ACCESS_TOKEN=your_access_token

# Choice 2: Service principal Client ID and OAuth secret (M2M auth) — uncomment these AND comment out the token above
TAP_DATABRICKS_CLIENT_ID=your_client_id
TAP_DATABRICKS_CLIENT_SECRET=your_client_secret

# set stream if want to run test for specific stream otherwise the first stream from teh catlog gets tested 
# when this is not set
TAP_DATABRICKS_TEST_STREAM=my_stream
